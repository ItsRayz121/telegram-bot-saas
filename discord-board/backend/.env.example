# ====================================================================
# Guildizer backend env — COPY this file to ".env" and fill in values.
# The real .env is git-ignored and must NEVER be committed.
# ====================================================================

# --- Discord application (from discord.com/developers/applications) ---
DISCORD_BOT_TOKEN=your-bot-token-here          # Bot tab -> Reset Token (SECRET)
DISCORD_CLIENT_ID=1514145107559845949          # OAuth2 -> Client ID (public)
DISCORD_CLIENT_SECRET=your-client-secret-here  # OAuth2 -> Reset Secret (SECRET)

# OAuth2 redirect — must match what's set in the Discord portal
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# Permission bitfield requested when inviting the bot. Leave blank to use the
# built-in default (manage roles/channels, moderate, post — NOT Administrator).
DISCORD_BOT_PERMISSIONS=

# --- Billing: NOWPayments (reuse the account; NEW separate IPN endpoint) ---
# IPN callback to set in the NOWPayments dashboard: <BACKEND_URL>/webhooks/nowpayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
PRO_PRICE_USD=9
PRO_PERIOD_DAYS=30

# --- Database (separate from Telegizer) ---
# Local dev can use sqlite; production uses the Railway Postgres URL.
DATABASE_URL=sqlite:///instance/guildizer.db

# --- Admin ---
# Comma-separated Discord user ids that may access the admin panel (/admin).
ADMIN_USER_IDS=

# --- Encryption (REQUIRED in production; same value on web + bot services!) ---
# Fernet key for custom-bot tokens at rest. Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from FLASK_SECRET_KEY (dev only — rotating the
# Flask secret would orphan every stored token).
GUILDIZER_ENCRYPTION_KEY=

# --- AI assistant (optional; all AI features are graceful when unset) ---
# Provider: openai (default) | openrouter | anthropic
#   openai     -> gpt-4o-mini does text AND vision (NSFW image checks) cheaply
#   openrouter -> OpenAI-compatible gateway, e.g. DeepSeek for cheap text
#   anthropic  -> Claude (legacy / fallback)
GUILDIZER_AI_PROVIDER=openai
# Set the key(s) you have. Image moderation uses OPENAI_API_KEY whenever it's set
# (even if the text provider is OpenRouter), so DeepSeek users still get vision.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
# Text model. Leave blank for the per-provider default
# (openai: gpt-4o-mini, openrouter: deepseek/deepseek-chat, anthropic: claude-haiku-4-5).
GUILDIZER_AI_MODEL=
# Vision model used for image/NSFW checks (OpenAI). Default is fine.
GUILDIZER_VISION_MODEL=gpt-4o-mini
GUILDIZER_AI_MAX_TOKENS=600

# --- App ---
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
# Path of the Guildizer section inside the frontend (production: /guildizer
# on telegizer.com). OAuth returns + checkout redirects land here.
GUILDIZER_FRONTEND_PATH=/guildizer
BACKEND_URL=http://localhost:5000
PORT=5000

# --- Session cookie ---
# Dev (frontend+api both on localhost) can stay Lax/insecure. In production,
# when the dashboard and API are on different domains, set:
#   SESSION_COOKIE_SECURE=true
#   SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_NAME=guildizer_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_MAX_AGE=1209600
