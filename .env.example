# ─────────────────────────────────────────────────────────────────────────────
# BotForge / Telegizer — Environment Variables Reference
# Copy to .env for local dev. Production values go in Railway (backend) and
# Vercel (frontend build) dashboards. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask core ────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-hex-32
JWT_SECRET_KEY=generate-with-python-secrets-token-hex-32
FLASK_ENV=production
FLASK_DEBUG=0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/telegizer

# ── Redis (JWT blocklist + rate-limiting) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Domains ───────────────────────────────────────────────────────────────────
# Public frontend URL — used in all email links (verify, reset password, etc.)
FRONTEND_URL=https://telegizer.xyz

# Public backend API URL — used in payment IPN callbacks
BACKEND_URL=https://api.telegizer.xyz

# CORS allowed origins (comma-separated). All three variants must be listed.
ALLOWED_ORIGINS=https://telegizer.xyz,https://app.telegizer.xyz,https://www.telegizer.xyz

# ── Email — Resend (preferred) ────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev          # or noreply@telegizer.xyz once domain verified

# ── Email — SMTP fallback (set EMAIL_PROVIDER=smtp to use) ───────────────────
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=your-app-password

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=you@example.com

# ── Encryption (Fernet key for bot tokens + TOTP secrets) ────────────────────
FERNET_KEY=generate-with-Fernet.generate_key-then-decode

# ── Payments — NOWPayments (crypto) ──────────────────────────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Payments — Lemon Squeezy (card/bank) ─────────────────────────────────────
LS_API_KEY=
LS_STORE_ID=
LS_PRO_VARIANT_ID=
LS_ENTERPRISE_VARIANT_ID=
LS_WEBHOOK_SECRET=

# ── Sentry error monitoring (optional) ───────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND BUILD — set in Vercel project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# REACT_APP_API_URL=https://api.telegizer.xyz
# REACT_APP_SENTRY_DSN=   (optional)
